# Vela env example. Copy to .env and fill in. Never commit real secrets.
# Per file 27, EXPO_PUBLIC_* vars are bundled into the client and visible.
# Service-role keys, Singular SDK secret, etc. live as EAS secrets only.

# --- Public (safe to bundle) ---
# Supabase project ref (Dashboard → Settings → General): nvpiykrwhmiszeqrmuzg — same ref as `.cursor/mcp.json` MCP URL.
EXPO_PUBLIC_API_ENV=development
EXPO_PUBLIC_SUPABASE_URL=https://nvpiykrwhmiszeqrmuzg.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Auth: enable Apple + Google in Supabase Dashboard → Authentication → Providers.
# Redirect URLs must include every `Linking.createURL('auth/callback')` value your
# builds use (e.g. vela://auth/callback, and Expo Go / dev-client URLs if you test there).
#
# Apple (Services ID + Team ID — for Supabase Apple provider + `scripts/decode-apple-p8.mjs --jwt`).
# Do not bundle these as EXPO_PUBLIC_* unless you intend to expose them in the client.
# APPLE_TEAM_ID=666MXKGN46
# APPLE_CLIENT_ID=com.velapp.auth
# Supabase → Auth → Apple → Client IDs (comma-separated): include the Services ID and every
# native bundle ID you use, e.g. com.velapp.auth,com.velapp.vela (single app id for dev + production)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxx
EXPO_PUBLIC_AI_PROXY_URL=https://nvpiykrwhmiszeqrmuzg.supabase.co/functions/v1/ai-proxy
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
EXPO_PUBLIC_SINGULAR_KEY=your_singular_sdk_key

# --- EAS-only (never EXPO_PUBLIC) ---
# Set via: eas secret:create --name SINGULAR_SECRET --value xxx --scope project
# These are read at build time by app.config.js, not at runtime.
SINGULAR_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
SENTRY_AUTH_TOKEN=
POSTMARK_SERVER_TOKEN=

# --- Supabase Edge secrets (supabase secrets set — never EXPO_PUBLIC) ---
# OPENAI_API_KEY — Chat Completions for `ai-proxy` (required in production).
# Optional: MODEL_FAST, MODEL_QUALITY — OpenAI model ids (defaults: gpt-4o-mini / gpt-4o).
# GENERATE_WRAPPED_INTERNAL_SECRET — cron/batch calls to `generate-monthly-wrapped` with header `x-vela-internal-secret`.
# REVENUECAT_WEBHOOK_SECRET — must match RevenueCat webhook Authorization (Bearer …)
#   for `record-subscription`. Optional: VELA_ENTITLEMENT_ID (defaults to vela_premium).
