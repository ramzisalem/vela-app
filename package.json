{
  "name": "vela",
  "version": "1.0.0",
  "description": "Vela — longitudinal face tracking. The Oura for your face.",
  "main": "expo-router/entry",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios --device",
    "ios:simulator": "expo start --ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest --no-watchman",
    "test:watch": "jest --watch --no-watchman",
    "test:ci": "jest --ci --coverage --no-watchman --runInBand",
    "check:contrast": "ts-node scripts/checkContrast.ts",
    "check:brand": "ts-node scripts/checkBrandVoice.ts",
    "e2e": "maestro test .maestro/",
    "supabase:start": "supabase start",
    "supabase:migrate": "supabase db push",
    "supabase:functions:deploy": "supabase functions deploy",
    "postinstall": "patch-package || true"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@nozbe/watermelondb": "^0.27.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-masked-view/masked-view": "0.3.1",
    "@react-native-picker/picker": "2.7.5",
    "@shopify/react-native-skia": "1.2.3",
    "@supabase/supabase-js": "^2.45.0",
    "date-fns": "^3.6.0",
    "expo": "~51.0.28",
    "expo-apple-authentication": "~6.4.2",
    "expo-application": "~5.9.1",
    "expo-auth-session": "~5.5.2",
    "expo-camera": "~15.0.16",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~13.0.2",
    "expo-dev-client": "~4.0.27",
    "expo-device": "~6.0.2",
    "expo-file-system": "~17.0.1",
    "expo-haptics": "~13.0.1",
    "expo-image-manipulator": "~12.0.5",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-localization": "~15.0.3",
    "expo-media-library": "~16.0.4",
    "expo-notifications": "~0.28.16",
    "expo-router": "~3.5.23",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~12.0.1",
    "expo-splash-screen": "~0.27.5",
    "expo-status-bar": "~1.12.1",
    "expo-tracking-transparency": "~4.0.2",
    "expo-web-browser": "~13.0.3",
    "posthog-react-native": "^3.16.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-purchases": "^8.12.0",
    "react-native-purchases-ui": "^8.12.0",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-view-shot": "3.8.0",
    "singular-react-native": "^4.1.0",
    "uuid": "^9.0.1",
    "vela-face-tracker": "file:./modules/vela-face-tracker",
    "victory-native": "^41.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@nozbe/with-observables": "^1.6.0",
    "@testing-library/react-native": "^12.5.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/react": "~18.2.79",
    "@types/react-native": "^0.72.8",
    "@types/uuid": "^9.0.8",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.1.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.3",
    "jsonwebtoken": "^9.0.2",
    "msw": "^2.4.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.5"
  },
  "overrides": {
    "ajv": "^8.12.0"
  }
}
